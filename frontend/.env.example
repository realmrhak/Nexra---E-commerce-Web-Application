# Frontend environment variables
# Copy this file to .env.local and fill in your values.

# Vite reads these. They MUST be prefixed with VITE_ to be exposed to the browser.
# In development, leave blank to use the Vite proxy (http://localhost:5000).
# In production (Vercel), set this to your Render backend URL.
VITE_API_URL=http://localhost:5000
