# ============ SERVER ============
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ============ DATABASE ============
# Get this from MongoDB Atlas → Connect → Drivers → connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/nexra?retryWrites=true&w=majority

# ============ JWT ============
# Generate a strong random string (e.g. `openssl rand -hex 64`)
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# ============ CLOUDINARY ============
# Cloudinary dashboard → Account details
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============ EMAIL (Nodemailer - for password reset) ============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Nexra <noreply@nexra.shop>

# ============ RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ============ SEED ADMIN USER (optional)
# These are used by `npm run seed` to create the admin user.
# If omitted, the seed script uses the following defaults:
#   admin@nexra.shop / Admin@123
# Override these in production!
SEED_ADMIN_NAME=Nexra Admin
SEED_ADMIN_EMAIL=admin@nexra.shop
SEED_ADMIN_PASSWORD=Admin@123


# ============ AUTO-SEED (optional)
# When the server starts, it checks if the database is empty.
# If empty, it auto-seeds default data (products, categories, users, coupons).
# Set to "false" to disable (e.g. in production after first deploy).
# Default: enabled (auto-seeds if DB is empty)
AUTO_SEED=true